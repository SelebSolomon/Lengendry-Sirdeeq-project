model Product {
  id                String   @id @default(uuid())
  name              String
  price             Float
  description       String
  stock             Int      @default(0)
  thumbnail         String
  thumbnailPublicId String
  images            String[]
  imagePublicIds    String[]
  categoryId        String
  vendorId          String
  ratings           Float    @default(0)
  date              DateTime @default(now())
  slug              String   @unique
  category          Category @relation(fields: [categoryId], references: [id])
  reviews           Review[]
  orderItems        OrderItem[]

  cartItems CartItem[]
}
